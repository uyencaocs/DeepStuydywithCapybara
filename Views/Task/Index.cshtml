@model IEnumerable<DeeplearningwithCapybara.Models.Tasks>
@{
    ViewData["Title"] = "Quản Lý Công Việc";
    var pendingTasks = Model.Where(t => t.Status == false).ToList();
    var completedTasks = Model.Where(t => t.Status == true).ToList();

    // Group pending tasks by PlanId for reschedule-all
    var planGroups = pendingTasks.GroupBy(t => t.PlanId).ToList();
}

<!-- FullCalendar CSS -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />

<div class="bg-[#FDF8F3] min-h-screen p-6 md:p-8 space-y-6">

    <!-- Header -->
    <div class="bg-white rounded-[3rem] border border-[#E8C9A0]/50 p-8 shadow-sm">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-3xl font-black text-[#5c3d1e] mb-2 flex items-center gap-2">
                    <iconify-icon icon="solar:checklist-bold-duotone" class="text-[#F4831F]"></iconify-icon>
                    Quản Lý Công Việc
                </h1>
                <p class="text-black/50 font-medium">Theo dõi và hoàn thành lộ trình học tập do AI đề xuất.</p>
            </div>
            <div class="flex gap-4 text-sm font-bold">
                <div class="bg-orange-50 border border-orange-200 rounded-2xl px-5 py-3 text-center">
                    <div class="text-2xl font-black text-[#F4831F]">@pendingTasks.Count</div>
                    <div class="text-[#8B5E3C]">Đang chờ</div>
                </div>
                <div class="bg-green-50 border border-green-200 rounded-2xl px-5 py-3 text-center">
                    <div class="text-2xl font-black text-green-600">@completedTasks.Count</div>
                    <div class="text-green-700">Hoàn thành</div>
                </div>
            </div>
        </div>
    </div>

    <!-- FullCalendar -->
    <div class="bg-white rounded-[2.5rem] border border-[#E8C9A0]/50 p-6 shadow-sm">
        <h3 class="text-xl font-black text-[#5c3d1e] mb-6 flex items-center gap-2">
            <iconify-icon icon="solar:calendar-bold-duotone" class="text-[#F4831F]" width="24"></iconify-icon>
            Lịch Học
        </h3>
        <div id="study-calendar" class="fc-custom"></div>
    </div>

    <!-- Task lists -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Đang chờ -->
        <div class="bg-white rounded-[2.5rem] border border-[#E8C9A0]/50 p-6 shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-[#6B4226] flex items-center gap-2">
                    <iconify-icon icon="solar:clock-circle-bold-duotone" class="text-[#F4831F]"></iconify-icon>
                    Sắp tới (@pendingTasks.Count)
                </h3>
                @if (planGroups.Any())
                {
                    <button onclick="rescheduleAll(@planGroups.First().Key)"
                            class="text-xs bg-[#3D2010] text-white px-4 py-2 rounded-xl font-bold hover:bg-black transition-all flex items-center gap-1">
                        <iconify-icon icon="solar:restart-bold" width="14"></iconify-icon>
                        Sắp xếp lại
                    </button>
                }
            </div>

            <div class="space-y-4 max-h-[600px] overflow-y-auto pr-1 custom-scrollbar">
                @foreach (var t in pendingTasks)
                {
                    var isLate = t.StartDate < DateTime.Now;
                    var priorityColor = t.Priority == 3 ? "#EF4444" : t.Priority == 2 ? "#F59E0B" : "#10B981";
                    var priorityLabel = t.Priority == 3 ? "🔴 Quan trọng" : t.Priority == 2 ? "🟡 Trung bình" : "🟢 Thấp";

                    <div class="task-item bg-[#FFFCF9] p-4 rounded-2xl border @(isLate ? "border-red-300 bg-red-50" : "border-[#F0DDC8]") relative" id="task-@t.TaskId"
                         style="border-left: 5px solid @priorityColor">
                        <div class="flex justify-between items-start mb-2">
                            <span class="inline-block px-2 py-1 text-xs font-bold rounded-lg"
                                  style="background: @(priorityColor)20; color: @priorityColor">
                                @priorityLabel
                            </span>
                            <button onclick="rescheduleTask(@t.TaskId)"
                                    class="text-xs text-[#9B7B52] font-semibold hover:text-[#6B4226] underline">
                                Đổi ngày
                            </button>
                        </div>

                        <h4 class="font-bold text-gray-800 mt-1">@t.TaskName</h4>
                        <p class="text-xs text-gray-500 mt-1">
                            📅 @t.StartDate.ToString("dd/MM/yyyy") — @t.EndDate.ToString("dd/MM/yyyy")
                            @if (isLate) { <span class="text-red-500 font-bold"> (Trễ!)</span> }
                        </p>

                        <div class="mt-3 flex gap-2">
                            <button onclick="completeTask(@t.TaskId)"
                                    class="flex-1 bg-[#8CA894] hover:bg-[#6e8a76] text-white text-sm font-bold py-2 rounded-xl transition-colors">
                                <iconify-icon icon="solar:check-circle-bold-duotone"></iconify-icon> Xong
                            </button>
                            <button onclick="postponeTask(@t.TaskId)"
                                    class="flex-1 bg-[#F4831F] hover:bg-[#d46d14] text-white text-sm font-bold py-2 rounded-xl transition-colors">
                                <iconify-icon icon="solar:calendar-bold-duotone"></iconify-icon> Hoãn 1 ngày
                            </button>
                        </div>
                    </div>
                }
                @if (!pendingTasks.Any())
                {
                    <div class="text-center py-12 text-gray-400">
                        <iconify-icon icon="solar:star-bold-duotone" width="48" class="text-[#F4831F]"></iconify-icon>
                        <p class="mt-2 font-medium">Không có công việc nào đang chờ.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Hoàn thành -->
        <div class="bg-[#F0FFF4] rounded-[2.5rem] border border-green-200 p-6 shadow-sm">
            <h3 class="text-xl font-bold text-[#2d6a4f] mb-6 flex items-center gap-2">
                <iconify-icon icon="solar:check-circle-bold-duotone" class="text-green-500"></iconify-icon>
                Đã hoàn thành (@completedTasks.Count)
            </h3>

            <div class="space-y-3 max-h-[600px] overflow-y-auto pr-1 custom-scrollbar opacity-75">
                @foreach (var t in completedTasks)
                {
                    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
                        <div>
                            <h4 class="font-bold text-gray-500 line-through decoration-gray-400">@t.TaskName</h4>
                            <p class="text-xs text-gray-400 mt-1">@t.StartDate.ToString("dd/MM/yyyy")</p>
                        </div>
                        <iconify-icon icon="solar:check-circle-bold-duotone" width="24" class="text-[#8CA894]"></iconify-icon>
                    </div>
                }
                @if (!completedTasks.Any())
                {
                    <div class="text-center py-12 text-gray-400">
                        <p class="font-medium">Chưa có công việc nào hoàn thành.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #E8C9A0; border-radius: 10px; }
    .fc-custom .fc-toolbar-title { font-weight: 900; color: #3D2010; }
    .fc-custom .fc-button-primary { background: #3D2010 !important; border-color: #3D2010 !important; border-radius: 0.75rem !important; font-weight: 700 !important; }
    .fc-custom .fc-daygrid-day-number { font-weight: 700; color: #5c3d1e; }
    .fc-custom .fc-event { border-radius: 8px !important; border: none !important; font-size: 11px !important; font-weight: 700 !important; }
</style>

<!-- FullCalendar JS -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>

<script>
    // ─── CALENDAR ─────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('study-calendar');

        // Build events from server-side model
        var events = [
            @foreach (var t in Model)
            {
                var color = t.Priority == 3 ? "#EF4444" : t.Priority == 2 ? "#F59E0B" : "#10B981";
                var status = t.Status ? "✅ " : "";
                @Html.Raw($"{{ id: {t.TaskId}, title: '{status}{t.TaskName.Replace("'", "\\'")}', start: '{t.StartDate:yyyy-MM-ddTHH:mm:ss}', end: '{t.EndDate:yyyy-MM-ddTHH:mm:ss}', backgroundColor: '{color}', borderColor: '{color}', extendedProps: {{ status: {(t.Status ? "true" : "false")} }} }},")
            }
        ];

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'vi',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,listWeek'
            },
            events: events,
            eventClick: function (info) {
                var taskId = info.event.id;
                var isDone = info.event.extendedProps.status;
                var title = info.event.title;
                if (isDone) {
                    alert('✅ Công việc "' + title + '" đã hoàn thành!');
                } else {
                    var action = confirm('📌 "' + title + '"\n\nNhấn OK để Hoàn thành, Cancel để Hoãn 1 ngày.');
                    if (action) completeTask(taskId);
                    else postponeTask(taskId);
                }
            },
            eventDidMount: function (info) {
                if (info.event.extendedProps.status) {
                    info.el.style.opacity = '0.5';
                    info.el.style.textDecoration = 'line-through';
                }
            }
        });
        calendar.render();
    });

    // ─── TASK ACTIONS ─────────────────────────────────────────────────────────
    async function completeTask(id) {
        if (!confirm("Bạn đã hoàn thành công việc này?")) return;
        try {
            const res = await fetch(`/task/complete/${id}`, { method: 'POST' });
            if (res.ok) { window.location.reload(); }
            else { alert("Lỗi khi cập nhật. Hãy thử đăng nhập lại."); }
        } catch (e) { console.error(e); }
    }

    async function postponeTask(id) {
        if (!confirm("Bạn muốn hoãn công việc này thêm 1 ngày?")) return;
        try {
            const res = await fetch(`/task/postpone/${id}`, { method: 'POST' });
            if (res.ok) { window.location.reload(); }
            else { alert("Lỗi khi cập nhật."); }
        } catch (e) { console.error(e); }
    }

    async function rescheduleTask(id) {
        const newDate = prompt("Nhập ngày mới theo định dạng YYYY-MM-DD:");
        if (!newDate) return;
        try {
            const res = await fetch(`/task/reschedule/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newDate })
            });
            if (res.ok) { window.location.reload(); }
            else { alert("Lỗi cập nhật hoặc ngày sai định dạng."); }
        } catch (e) { console.error(e); }
    }

    async function rescheduleAll(planId) {
        if (!confirm("Tính toán lại toàn bộ lịch học chưa hoàn thành từ hôm nay đến kỳ thi?")) return;
        try {
            const res = await fetch(`/task/reschedule-all/${planId}`, { method: 'POST' });
            const data = await res.json();
            if (res.ok) {
                alert(`✅ Đã sắp xếp lại ${data.rescheduled} công việc thành công!`);
                window.location.reload();
            } else {
                alert("Không thể sắp xếp lại lịch.");
            }
        } catch (e) { console.error(e); }
    }
</script>
