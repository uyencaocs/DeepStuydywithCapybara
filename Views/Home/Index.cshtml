@{
    ViewData["Title"] = "Trang Chủ - CapyStudy AI";
}

<div class="bg-[#FDF8F3] min-h-screen p-4 md:p-8 space-y-8">

    <div class="bg-white rounded-[3rem] border border-[#E8C9A0]/50 p-8 md:p-12 shadow-sm relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-[#FDF8F3] rounded-full blur-3xl group-hover:bg-[#E8C9A0]/20 transition-colors duration-700"></div>

        <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left flex-1">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#FDF8F3] border border-[#E8C9A0] mb-4">
                    <iconify-icon icon="solar:magic-stick-3-bold-duotone" width="18" class="text-[#F4831F]"></iconify-icon>
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#8B5E3C]">AI Study Assistant</span>
                </div>
                <h1 class="text-3xl md:text-5xl font-black text-black leading-tight mb-3">
                    <span id="greeting-text">Đang tải...</span>
                    <span id="greeting-icon" class="inline-block hover:rotate-12 transition-transform cursor-default">☕</span>
                </h1>
                <p id="greeting-sub" class="text-base md:text-lg font-medium text-black/50 max-w-xl">
                    Hãy để Capy giúp Uyên tối ưu hóa lộ trình học tập hôm nay nhé! ✨
                </p>
            </div>

            <div class="flex flex-col items-center gap-4">
                <div class="relative">
                    <img src="~/images/capybaraa photocopy.jpg" alt="Capy"
                         class="w-24 h-24 md:w-32 md:h-32 object-cover rounded-[2rem] border-4 border-white shadow-xl rotate-3 hover:rotate-0 transition-all duration-500" />
                    <div class="absolute -bottom-2 -right-2 bg-white p-2 rounded-xl shadow-lg border border-[#E8C9A0]">
                        <iconify-icon icon="solar:heart-bold" width="20" class="text-red-400 animate-pulse"></iconify-icon>
                    </div>
                </div>
                <button id="btn-scroll-to-form" class="group flex items-center gap-3 bg-[#3D2010] text-white px-6 py-3 rounded-2xl font-bold hover:bg-black transition-all active:scale-95 shadow-lg">
                    <iconify-icon icon="solar:add-circle-bold-duotone" width="22"></iconify-icon>
                    <span>Lên lịch học mới</span>
                </button>
            </div>
        </div>
    </div>

    <div id="planner-form-panel" class="glass-card max-w-4xl mx-auto p-6 md:p-10 transition-all duration-500">
        <div class="form-panel-header mb-8">
            <h2 class="text-2xl font-black text-[#3D2010] flex items-center gap-3">
                <iconify-icon icon="solar:notebook-bookmark-bold-duotone" width="28"></iconify-icon>
                Thông tin lộ trình học
            </h2>
            <div class="h-1 w-20 bg-[#F4831F] mt-2 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="field-group md:col-span-2">
                <label for="f-subject">Tên môn học / Mục tiêu <span class="text-red-500">*</span></label>
                <input id="f-subject" type="text" placeholder="VD: Deep Learning, TOEIC 900..." class="field-input" />
            </div>

            <div class="field-group">
                <label for="f-start-date">Ngày bắt đầu</label>
                <input id="f-start-date" type="date" class="field-input" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="field-group">
                <label for="f-deadline">Ngày thi / Deadline <span class="text-red-500">*</span></label>
                <input id="f-deadline" type="date" class="field-input" />
            </div>

            <div class="field-group">
                <label for="f-priority">Mức độ quan trọng</label>
                <select id="f-priority" class="field-input">
                    <option value="1">🟢 Thấp (Duy trì)</option>
                    <option value="2" selected>🟡 Trung bình (Cần tập trung)</option>
                    <option value="3">🔴 Cao (Cực kỳ quan trọng)</option>
                </select>
            </div>

            <div class="field-group">
                <label for="f-level">Trình độ hiện tại</label>
                <select id="f-level" class="field-input">
                    <option value="Mới bắt đầu">🌱 Mới bắt đầu</option>
                    <option value="Trung bình" selected>📘 Trung bình</option>
                    <option value="Nâng cao">🚀 Nâng cao</option>
                </select>
            </div>

            <div class="field-group">
                <label>Thời gian học / ngày (giờ)</label>
                <div class="hours-control flex gap-2">
                    <button class="hours-btn" id="btn-hour-minus" type="button">−</button>
                    <input id="f-hours" type="number" value="2" step="0.5" class="field-input text-center" readonly />
                    <button class="hours-btn" id="btn-hour-plus" type="button">+</button>
                </div>
            </div>

            <div class="field-group">
                <label for="f-style">Cách học yêu thích</label>
                <select id="f-style" class="field-input">
                    <option value="Thực hành dự án">⚙️ Thực hành / Làm dự án</option>
                    <option value="Xem video bài giảng">🎬 Video bài giảng</option>
                    <option value="Flashcard">🃏 Flashcard & Ôn tập nhanh</option>
                </select>
            </div>
        </div>

        <button id="btn-generate" class="btn-generate mt-10 group">
            <iconify-icon icon="solar:magic-stick-3-bold-duotone" width="24" class="group-hover:rotate-45 transition-transform"></iconify-icon>
            Hỏi AI để tạo lộ trình
        </button>
    </div>

    <div id="result-panel" style="display:none;" class="space-y-6">
        <div class="result-header-card glass-card">
            <div class="result-meta grid grid-cols-2 md:grid-cols-4 gap-4">
            </div>
        </div>

        <div class="sessions-panel glass-card">
            <h3 class="card-title text-xl font-black mb-6 flex items-center gap-2">
                <iconify-icon icon="solar:calendar-bold-duotone" width="24"></iconify-icon>
                Chi tiết lộ trình đề xuất
            </h3>
            <div id="sessions-list" class="space-y-4 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
            </div>
        </div>

        <div class="flex justify-center gap-4">
            <button id="btn-save" class="bg-green-600 text-white px-8 py-3 rounded-2xl font-bold hover:bg-green-700 transition-all shadow-lg flex items-center gap-2">
                <iconify-icon icon="solar:diskette-bold-duotone" width="20"></iconify-icon>
                Lưu vào Lịch trình
            </button>
            <button id="btn-reset" class="bg-gray-200 text-gray-700 px-8 py-3 rounded-2xl font-bold hover:bg-gray-300 transition-all">
                Làm lại
            </button>
        </div>
    </div>

    <div id="loading-state" style="display:none;" class="flex flex-col items-center py-20">
        <iconify-icon icon="solar:magic-stick-3-bold-duotone" width="64" class="text-[#F4831F] animate-spin"></iconify-icon>
        <p class="mt-4 font-bold text-[#8B5E3C]">AI đang "nhào nặn" lộ trình cho Uyên...</p>
    </div>

</div>

<style>
    .glass-card {
        background: white;
        border: 1px solid #E8C9A0;
        border-radius: 2.5rem;
        box-shadow: 0 10px 30px -10px rgba(107,66,38,0.1);
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .field-group label {
            font-size: 0.85rem;
            font-weight: 800;
            color: #5C3D1E;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

    .field-input {
        width: 100%;
        padding: 0.8rem 1.2rem;
        border: 2px solid #F3E2CC;
        border-radius: 1.2rem;
        outline: none;
        font-weight: 600;
        transition: all 0.3s;
    }

        .field-input:focus {
            border-color: #F4831F;
            background: #FFFBF7;
        }

    .hours-btn {
        width: 45px;
        height: 45px;
        background: #FDF1E3;
        border: 2px solid #F3E2CC;
        border-radius: 1rem;
        font-size: 1.5rem;
        font-weight: bold;
        cursor: pointer;
        color: #3D2010;
    }

    .btn-generate {
        width: 100%;
        padding: 1.2rem;
        background: linear-gradient(135deg, #3D2010 0%, #000 100%);
        color: white;
        border-radius: 1.5rem;
        font-size: 1.1rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .session-card {
        display: flex;
        gap: 15px;
        padding: 1.2rem;
        border-radius: 1.5rem;
        border: 1px solid #F3E2CC;
        background: #FFFCF9;
        border-left: 6px solid #F4831F;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #E8C9A0;
        border-radius: 10px;
    }
</style>
@section Scripts {
    <script>
        (function () {
            // ─── UPDATE GREETING ───────────────────────────────────
            function updateGreeting() {
                const textEl = document.getElementById('greeting-text');
                const subEl = document.getElementById('greeting-sub');
                const hour = new Date().getHours();
                if (hour >= 5 && hour < 11) { textEl.innerText = "Chào buổi sáng!"; subEl.innerText = "Sẵn sàng cho một ngày học tập bùng nổ chưa Uyên?"; }
                else if (hour >= 11 && hour < 14) { textEl.innerText = "Chào buổi trưa!"; subEl.innerText = "Ăn ngon miệng và dành chút thời gian lập kế hoạch nhé!"; }
                else if (hour >= 14 && hour < 18) { textEl.innerText = "Chào buổi chiều!"; subEl.innerText = "Tập trung cao độ cùng Capy để xong bài sớm nào!"; }
                else { textEl.innerText = "Chào buổi tối!"; subEl.innerText = "Sắp xếp lại công việc và chuẩn bị nghỉ ngơi thôi Uyên ơi!"; }
            }
            updateGreeting();

            // ─── STATE ─────────────────────────────────────────────
            let currentData = null;

            // ─── UI CONTROLS ───────────────────────────────────────
            document.getElementById('btn-hour-plus').onclick = () => {
                let inp = document.getElementById('f-hours');
                inp.value = Math.min(12, parseFloat(inp.value) + 0.5);
            };
            document.getElementById('btn-hour-minus').onclick = () => {
                let inp = document.getElementById('f-hours');
                inp.value = Math.max(0.5, parseFloat(inp.value) - 0.5);
            };
            document.getElementById('btn-scroll-to-form').onclick = () => {
                document.getElementById('planner-form-panel').scrollIntoView({ behavior: 'smooth' });
            };

            // ─── GENERATE AI ADVISE ───────────────────────────────
            document.getElementById('btn-generate').onclick = async () => {
                const payload = {
                    subject: document.getElementById('f-subject').value,
                    startDate: document.getElementById('f-start-date').value,
                    deadline: document.getElementById('f-deadline').value,
                    priority: parseInt(document.getElementById('f-priority').value),
                    level: document.getElementById('f-level').value,
                    studyHoursPerDay: parseFloat(document.getElementById('f-hours').value),
                    studyStyle: document.getElementById('f-style').value
                };

                if (!payload.subject || !payload.deadline) {
                    alert("Uyên nhớ điền Tên môn học và Deadline nhé!"); return;
                }

                document.getElementById('planner-form-panel').style.display = 'none';
                document.getElementById('loading-state').style.display = 'flex';

                try {
                    const res = await fetch('/api/ai/schedule-advise', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) throw new Error("Server không phản hồi");

                    currentData = await res.json();
                    renderResult(currentData);
                } catch (e) {
                    alert("Lỗi: " + e.message);
                    document.getElementById('planner-form-panel').style.display = 'block';
                } finally {
                    document.getElementById('loading-state').style.display = 'none';
                }
            };

            function renderResult(data) {
                const list = document.getElementById('sessions-list');
                list.innerHTML = data.tasks.map((t, idx) => `
                    <div class="session-card" style="border-left-color: ${getPriorityColor(t.priority)}">
                        <div class="font-black text-2xl text-gray-200">#${idx+1}</div>
                        <div class="flex-1">
                            <div class="font-bold text-lg">${t.taskName}</div>
                            <div class="text-sm text-gray-500">
                                📅 ${new Date(t.startDate).toLocaleDateString('vi-VN')} - ${new Date(t.endDate).toLocaleDateString('vi-VN')}
                                | ⏱️ ${t.duration}
                            </div>
                        </div>
                        <div class="flex items-center">
                            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase"
                                  style="background: ${getPriorityColor(t.priority)}20; color: ${getPriorityColor(t.priority)}">
                                ${t.priority === 3 ? '🔴 Quan trọng' : t.priority === 2 ? '🟡 Trung bình' : '🟢 Thấp'}
                            </span>
                        </div>
                    </div>
                `).join('');
                document.getElementById('result-panel').style.display = 'block';
            }

            function getPriorityColor(p) {
                if (p == 3) return "#EF4444"; // Đỏ
                if (p == 2) return "#F59E0B"; // Vàng
                return "#10B981"; // Xanh lá
            }

            // ─── SAVE TO DB ───────────────────────────────────────
            document.getElementById('btn-save').onclick = async () => {
                try {
                    const res = await fetch('/api/ai/save-schedule', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(currentData)
                    });
                    if (res.ok) {
                        alert("Tuyệt vời Uyên ơi! Lịch học đã được lưu.");
                        window.location.href = "/Task";
                    } else {
                        alert("Lưu thất bại, hãy kiểm tra đăng nhập.");
                    }
                } catch (e) { alert("Lỗi kết nối."); }
            };

            document.getElementById('btn-reset').onclick = () => location.reload();
        })();
    </script>
}