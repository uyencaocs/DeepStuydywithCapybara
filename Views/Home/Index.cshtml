@{
    ViewData["Title"] = "Trang Chủ - CapyStudy AI";
}

<div class="bg-[#FDF8F3] min-h-screen p-6 md:p-8 space-y-6">

    <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 md:p-8 shadow-sm">
        <h1 class="text-2xl md:text-3xl font-black text-black mb-2 flex items-center gap-2">
            Chào buổi chiều! ☕
        </h1>
        <p class="text-sm font-semibold text-black/60 mb-6">Đừng quên nghỉ ngơi một chút giữa các task nhé. Hãy để AI gợi ý lộ trình ngay.</p>

        <div class="flex flex-col md:flex-row gap-4 mb-4">
            <div class="flex-1 flex items-center border border-[#E8C9A0] rounded-xl px-4 py-3 bg-white">
                <iconify-icon icon="solar:server-square-outline" width="20" class="text-[#8B5E3C] mr-3"></iconify-icon>
                <input type="text" placeholder="Nhập tên môn học (vd: Deep Learning)"
                       class="w-full bg-transparent outline-none text-sm font-semibold text-black placeholder:text-black/40" />
            </div>

            <div class="flex items-center border border-[#E8C9A0] rounded-xl px-4 py-3 bg-white">
                <iconify-icon icon="solar:calendar-linear" width="20" class="text-black/60 mr-2"></iconify-icon>
                <input type="text" placeholder="dd/mm/yyyy" class="bg-transparent outline-none text-sm font-semibold text-black w-28" />
            </div>

            <button class="bg-[#3D2010] text-white rounded-xl px-6 py-3 text-sm font-bold flex items-center justify-center gap-2 hover:bg-[#6B4226] transition-colors">
                <iconify-icon icon="solar:pen-new-square-linear" width="18"></iconify-icon> Hỏi AI
            </button>

            <div class="hidden md:flex ml-2 items-center justify-center">
                <img src="~/images/capybaraa photocopy.jpg" alt="Capy" class="w-12 h-12 object-cover rounded-full border border-[#E8C9A0] shadow-sm" />
            </div>
        </div>

        <div class="flex flex-wrap gap-4">
            <button class="border border-[#E8C9A0] rounded-xl px-4 py-2 flex items-center gap-2 text-sm font-bold text-black bg-white hover:bg-[#FDF1E3] transition-colors">
                <iconify-icon icon="solar:star-fall-minimalistic-bold-duotone" width="18" class="text-orange-500"></iconify-icon> Mức độ <iconify-icon icon="solar:alt-arrow-down-linear" class="text-black/50"></iconify-icon>
            </button>
            <button class="border border-[#E8C9A0] rounded-xl px-4 py-2 flex items-center gap-2 text-sm font-bold text-black bg-white hover:bg-[#FDF1E3] transition-colors">
                <iconify-icon icon="solar:clock-circle-bold-duotone" width="18" class="text-sky-500"></iconify-icon> Thời lượng <iconify-icon icon="solar:alt-arrow-down-linear" class="text-black/50"></iconify-icon>
            </button>
            <button class="border border-[#E8C9A0] rounded-xl px-4 py-2 flex items-center gap-2 text-sm font-bold text-black bg-white hover:bg-[#FDF1E3] transition-colors">
                <iconify-icon icon="solar:target-bold-duotone" width="18" class="text-emerald-500"></iconify-icon> Mục tiêu <iconify-icon icon="solar:alt-arrow-down-linear" class="text-black/50"></iconify-icon>
            </button>
            <button class="border border-[#E8C9A0] rounded-xl px-4 py-2 flex items-center gap-2 text-sm font-bold text-black bg-white hover:bg-[#FDF1E3] transition-colors">
                <iconify-icon icon="solar:pen-bold-duotone" width="18" class="text-indigo-500"></iconify-icon> Cách học <iconify-icon icon="solar:alt-arrow-down-linear" class="text-black/50"></iconify-icon>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 flex flex-col justify-between h-36 shadow-sm">
            <div class="flex justify-between items-start">
                <span class="text-xs font-black uppercase text-black">Lửa học tập</span>
                <div class="bg-orange-50 p-2 rounded-xl"><iconify-icon icon="solar:fire-bold-duotone" class="text-orange-500 text-xl"></iconify-icon></div>
            </div>
            <div class="text-2xl font-black text-black mt-4">12 <span class="text-sm font-bold">Ngày</span></div>
        </div>

        <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 flex flex-col justify-between h-36 shadow-sm">
            <div class="flex justify-between items-start">
                <span class="text-xs font-black uppercase text-black">Tiến độ tuần</span>
                <div class="bg-sky-50 p-2 rounded-xl"><iconify-icon icon="solar:chart-square-bold-duotone" class="text-sky-500 text-xl"></iconify-icon></div>
            </div>
            <div class="text-2xl font-black text-black mt-4">85 <span class="text-sm font-bold">%</span></div>
        </div>

        <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 flex flex-col justify-between h-36 shadow-sm">
            <div class="flex justify-between items-start">
                <span class="text-xs font-black uppercase text-black">Hoàn thành</span>
                <div class="bg-emerald-50 p-2 rounded-xl"><iconify-icon icon="solar:check-circle-bold-duotone" class="text-emerald-500 text-xl"></iconify-icon></div>
            </div>
            <div class="text-2xl font-black text-black mt-4">14 <span class="text-sm font-bold">Task</span></div>
        </div>

        <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 flex flex-col justify-between h-36 shadow-sm">
            <div class="flex justify-between items-start">
                <span class="text-xs font-black uppercase text-black">Giờ tập trung</span>
                <div class="bg-indigo-50 p-2 rounded-xl"><iconify-icon icon="solar:clock-circle-bold-duotone" class="text-indigo-500 text-xl"></iconify-icon></div>
            </div>
            <div class="text-2xl font-black text-black mt-4">128 <span class="text-sm font-bold">Giờ</span></div>
        </div>

    </div>

    <div class="bg-white rounded-[2rem] border border-[#E8C9A0] p-6 md:p-8 shadow-sm">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-lg font-black text-black flex items-center gap-2">
                <iconify-icon icon="solar:list-check-bold-duotone" class="text-[#8B5E3C]"></iconify-icon>
                Danh sách Task (Hôm nay)
            </h2>
            <span class="bg-[#FFF4E5] text-[#F4831F] text-[10px] font-black uppercase px-4 py-2 rounded-xl border border-[#F4831F]/20">3 Cần làm</span>
        </div>

        <div class="space-y-4">

            <div class="border border-[#E8C9A0] rounded-2xl p-4 flex justify-between items-center hover:bg-[#FDF8F3] transition-colors">
                <div class="flex items-center gap-4">
                    <div class="w-1.5 h-1.5 bg-[#8B5E3C] rounded-full"></div>
                    <span class="text-sm font-bold text-black">Hoàn thành Slide Chương 4 Deep Learning</span>
                </div>
                <div class="flex items-center gap-1 bg-orange-50 text-orange-600 px-3 py-1.5 rounded-lg text-xs font-bold border border-orange-100">
                    <iconify-icon icon="solar:clock-circle-linear"></iconify-icon> 10:00
                </div>
            </div>

            <div class="border border-[#E8C9A0] rounded-2xl p-4 flex justify-between items-center hover:bg-[#FDF8F3] transition-colors">
                <div class="flex items-center gap-4">
                    <div class="w-1.5 h-1.5 bg-[#8B5E3C] rounded-full"></div>
                    <span class="text-sm font-bold text-black">Luyện nghe TOEIC Part 3 (30 phút)</span>
                </div>
                <div class="flex items-center gap-1 bg-[#FDF1E3] text-[#8B5E3C] px-3 py-1.5 rounded-lg text-xs font-bold border border-[#E8C9A0]/50">
                    <iconify-icon icon="solar:clock-circle-linear"></iconify-icon> 14:30
                </div>
            </div>

        </div>
    </div>

</div>