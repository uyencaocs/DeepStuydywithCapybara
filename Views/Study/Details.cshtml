@model DeeplearningwithCapybara.Models.StudyPlans
@{
    ViewData["Title"] = "Study Plan Details";
    var tasks = ViewBag.Tasks as IEnumerable<DeeplearningwithCapybara.Models.Tasks>;
}

<div class="p-8 max-w-7xl mx-auto w-full flex flex-col lg:flex-row gap-8">
    <!-- Main Content: Plan Info and Tasks -->
    <div class="flex-1 space-y-8">
        <section class="bg-white/50 p-8 rounded-[2rem] border border-capy-primary/10 flex flex-col md:flex-row md:items-center justify-between gap-6 relative overflow-hidden">
            <div class="absolute -right-10 -bottom-10 opacity-10">
                <iconify-icon icon="solar:book-bookmark-bold-duotone" width="180"></iconify-icon>
            </div>
            <div class="z-10">
                <a href="@Url.Action("Index")" class="text-sm font-bold text-black hover:text-capy-primary flex items-center gap-1 mb-4 w-fit">
                    <iconify-icon icon="solar:alt-arrow-left-linear" width="18"></iconify-icon> Trở lại
                </a>
                <h1 class="text-3xl font-extrabold text-black">Môn: @Model.Courses?.CourseName</h1>
                <p class="text-black mt-2 font-medium">Ghi chú: @Model.Note</p>
                <div class="mt-4 flex gap-4">
                    <span class="bg-slate-100 text-black px-3 py-1.5 rounded-xl text-sm font-bold flex items-center gap-2">
                        <iconify-icon icon="solar:calendar-bold-duotone"></iconify-icon> @Model.ExamDate.ToString("dd/MM/yyyy HH:mm")
                    </span>
                    <span class="bg-slate-100 text-black px-3 py-1.5 rounded-xl text-sm font-bold flex items-center gap-2">
                        <iconify-icon icon="solar:map-point-bold-duotone"></iconify-icon> Phòng: @Model.Room
                    </span>
                </div>
            </div>
        </section>

        <!-- Tasks List -->
        <section class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-extrabold text-black">Danh sách công việc (Tasks)</h2>
            </div>

            <!-- Task Form -->
            <form action="@Url.Action("CreateTask", "Study")" method="post" class="flex flex-col md:flex-row gap-4 mb-8 bg-slate-50 p-4 rounded-[1.5rem]">
                <input type="hidden" name="PlanId" value="@Model.ExamId" />
                <input type="text" name="TaskName" required placeholder="Nội dung task..." class="flex-1 bg-white border border-slate-200 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-capy-primary/20 focus:border-capy-primary font-bold shadow-sm">
                <input type="datetime-local" name="Deadline" required class="bg-white border border-slate-200 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-capy-primary/20 focus:border-capy-primary font-bold shadow-sm">
                <button type="submit" class="bg-capy-primary text-white font-extrabold px-6 py-3 rounded-xl shadow-lg shadow-capy-primary/30 hover:bg-capy-brownHover transition-all flex justify-center items-center">
                    <iconify-icon icon="solar:add-circle-bold-duotone" width="24"></iconify-icon>
                </button>
            </form>

            <div class="space-y-4">
                @if (tasks != null && tasks.Any())
                {
                    foreach (var task in tasks)
                    {
                        var isCompleted = task.Status == "Completed";
                        <div class="flex flex-col md:flex-row justify-between items-center p-5 rounded-2xl border @(isCompleted ? "border-green-200 bg-green-50/50" : "border-slate-100 bg-white shadow-sm hover:border-capy-primary/30") transition-all group">
                            <div class="flex items-center gap-4 w-full md:w-auto">
                                <input type="checkbox" onchange="toggleTaskStatus(@task.TaskId, this)" @(isCompleted ? "checked" : "") class="w-6 h-6 rounded-lg text-capy-primary focus:ring-capy-primary border-slate-300">
                                <div>
                                    <h3 class="font-extrabold @(isCompleted ? "text-black line-through" : "text-black") transition-all">@task.TaskName</h3>
                                    <p class="text-xs font-bold text-black mt-1 flex items-center gap-1">
                                        <iconify-icon icon="solar:clock-circle-bold"></iconify-icon> Deadline: @task.Deadline.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                </div>
                            </div>
                            
                            <div class="flex gap-2 mt-4 md:mt-0 w-full md:w-auto opacity-100 md:opacity-0 group-hover:opacity-100 transition-opacity">
                                @if(!isCompleted)
                                {
                                    <button onclick="startFocus(@task.TaskId, '@task.TaskName')" class="flex-1 md:flex-none text-xs bg-red-50 text-black hover:bg-red-100 font-extrabold px-4 py-2 rounded-xl border border-red-100 transition-all flex items-center justify-center gap-1">
                                        <iconify-icon icon="solar:stopwatch-play-bold-duotone" width="16"></iconify-icon> TẬP TRUNG
                                    </button>
                                }
                                <form action="@Url.Action("DeleteTask", "Study")" method="post" class="flex-1 md:flex-none">
                                    <input type="hidden" name="TaskId" value="@task.TaskId" />
                                    <input type="hidden" name="PlanId" value="@Model.ExamId" />
                                    <button type="submit" onclick="return confirm('Bạn có chắc chắn muốn xóa task này?')" class="w-full h-full text-black hover:text-black hover:bg-red-50 p-2 rounded-xl transition-all flex items-center justify-center">
                                        <iconify-icon icon="solar:trash-bin-trash-bold-duotone" width="20"></iconify-icon>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-10 text-black font-bold">
                        Vẫn chưa có task nào. Hãy thêm ngay bên trên nhé! ✨
                    </div>
                }
            </div>
        </section>
    </div>

    <!-- Pomodoro Widget -->
    <div class="lg:w-80 space-y-6 shrink-0 z-20">
        <div id="pomodoro-widget" class="bg-[#2D3047] text-white rounded-[2.5rem] p-8 shadow-xl shadow-slate-200/50 sticky top-8 transform transition-transform border border-slate-700">
            <div class="flex justify-between items-center mb-6">
                <span class="text-xs font-extrabold tracking-widest uppercase text-red-400 flex items-center gap-1">
                    <iconify-icon icon="solar:fire-bold-duotone"></iconify-icon> Pomodoro
                </span>
                <button onclick="resetTimer()" title="Reset Timer" class="text-black hover:text-white transition-colors">
                    <iconify-icon icon="solar:restart-bold" width="20"></iconify-icon>
                </button>
            </div>
            
            <div id="current-focus-task" class="text-sm font-bold text-slate-300 text-center mb-6 h-10 flex items-center justify-center">
                Chưa chọn task nào
            </div>

            <!-- Timer Display -->
            <div class="relative w-48 h-48 mx-auto mb-8 flex items-center justify-center">
                <!-- Outer Ring -->
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="45" fill="none" stroke="#3D405B" stroke-width="8" />
                    <circle id="timer-ring" cx="50" cy="50" r="45" fill="none" stroke="#F18F01" stroke-width="8" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="0" class="transition-all duration-1000 ease-linear" />
                </svg>
                <!-- Timer Text -->
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span id="timer-display" class="text-5xl font-black tracking-tighter">25:00</span>
                    <span id="timer-status" class="text-[0.65rem] font-bold text-black uppercase tracking-widest mt-1">SẴN SÀNG</span>
                </div>
            </div>

            <!-- Controls -->
            <div class="flex justify-center gap-4">
                <button id="btn-start" onclick="toggleTimer()" class="bg-[#F18F01] hover:bg-[#D57B00] text-white w-16 h-16 rounded-3xl flex items-center justify-center shadow-lg active:scale-95 transition-all">
                    <iconify-icon id="play-icon" icon="solar:play-bold" width="28"></iconify-icon>
                </button>
            </div>
            
            <div class="mt-8 flex justify-center gap-2">
                <button onclick="setMode(25)" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-white/10 hover:bg-white/20 transition-colors">25m</button>
                <button onclick="setMode(5)" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-white/10 hover:bg-white/20 transition-colors text-slate-300">5m Break</button>
            </div>
            
            <input type="hidden" id="focus-task-id" value="">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Update Task Status AJAX
        function toggleTaskStatus(taskId, checkbox) {
            const status = checkbox.checked ? "Completed" : "Pending";
            
            $.post('/Study/UpdateTaskStatus', { TaskId: taskId, Status: status }, function(response) {
                if(response.success) {
                    // Quick reload to update progress UI
                    window.location.reload();
                } else {
                    alert("Lỗi khi cập nhật trạng thái");
                    checkbox.checked = !checkbox.checked;
                }
            });
        }

        // Pomodoro State
        let timerInterval;
        let isRunning = false;
        let timeRemaining = 25 * 60; // 25 mins in seconds
        let totalTime = 25 * 60;
        
        const timerDisplay = document.getElementById('timer-display');
        const timerRing = document.getElementById('timer-ring');
        const playIcon = document.getElementById('play-icon');
        const timerStatus = document.getElementById('timer-status');
        
        function formatTime(seconds) {
            const mins = Math.floor(seconds / 60);
            const secs = seconds % 60;
            return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }
        
        function updateDisplay() {
            timerDisplay.textContent = formatTime(timeRemaining);
            
            // Calculate stroke-dashoffset (283 is the max circumstance)
            const progress = (timeRemaining / totalTime);
            timerRing.style.strokeDashoffset = 283 - (progress * 283);
        }

        function setMode(mins) {
            if(isRunning) toggleTimer(); // stop if running
            totalTime = mins * 60;
            timeRemaining = totalTime;
            updateDisplay();
            timerRing.style.stroke = mins === 5 ? '#81B29A' : '#F18F01';
            timerStatus.textContent = mins === 5 ? 'NGHỈ GIẢO LAO' : 'SẴN SÀNG';
        }

        function toggleTimer() {
            if (isRunning) {
                clearInterval(timerInterval);
                playIcon.setAttribute('icon', 'solar:play-bold');
                timerStatus.textContent = 'TẠM DỪNG';
            } else {
                if (timeRemaining === 0) return;
                
                timerStatus.textContent = 'ĐANG TẬP TRUNG...';
                playIcon.setAttribute('icon', 'solar:pause-bold');
                
                timerInterval = setInterval(() => {
                    timeRemaining--;
                    updateDisplay();
                    
                    if (timeRemaining <= 0) {
                        clearInterval(timerInterval);
                        playIcon.setAttribute('icon', 'solar:play-bold');
                        timerStatus.textContent = 'HOÀN THÀNH 🎉';
                        isRunning = false;
                        
                        // Notify User via sound or alert
                        alert("Hết giờ! Giỏi lắm chiến binh 🚀");
                        
                        // Auto-check task if they were focusing on one
                        const focusTaskId = document.getElementById('focus-task-id').value;
                        if(focusTaskId && totalTime === 25 * 60) {
                            if(confirm("Bạn có muốn đánh dấu hoàn thành Task này luôn không?")) {
                                const checkbox = document.querySelector(`input[onchange*='${focusTaskId}']`);
                                if(checkbox && !checkbox.checked) {
                                    checkbox.checked = true;
                                    toggleTaskStatus(focusTaskId, checkbox);
                                }
                            }
                        }
                    }
                }, 1000);
            }
            isRunning = !isRunning;
        }

        function resetTimer() {
            if(isRunning) toggleTimer();
            timeRemaining = totalTime;
            updateDisplay();
            timerStatus.textContent = 'SẴN SÀNG';
        }

        function startFocus(taskId, taskName) {
            document.getElementById('current-focus-task').innerHTML = `<span class="bg-white/10 px-3 py-1.5 rounded-lg line-clamp-1">🎯 ${taskName}</span>`;
            document.getElementById('focus-task-id').value = taskId;
            setMode(25);
            
            // smooth scroll to widget
            document.getElementById('pomodoro-widget').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    </script>
}
