@{
    ViewData["Title"] = "Tập Trung Đầu Óc";
    // We override the layout here or just apply dark classes
}

<!-- Use a full-screen layout to override standard margin/padding -->
<div class="fixed inset-0 z-50 flex items-center justify-center bg-[#1E1108] text-white overflow-hidden" id="focus-container">
    
    <!-- Dynamic Background Image (Blurry) -->
    <div class="absolute inset-0 z-0 opacity-40 mix-blend-luminosity">
        <img id="bg-image" src="~/images/tải xuống (1).jpg" alt="Focus Background" class="w-full h-full object-cover blur-sm scale-105 transition-all duration-1000">
    </div>
    
    <!-- Gradient Overlay for Contrast -->
    <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#1E1108] via-[#3D2010]/80 to-[#1E1108]/90"></div>

    <!-- Top Left Escape Button -->
    <a href="@Url.Action("Index", "Home")" class="absolute top-8 left-8 z-20 flex items-center gap-2 text-[#E8C9A0] hover:text-white transition-colors group">
        <div class="w-10 h-10 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center border border-white/20 group-hover:bg-white/20 transition-all">
            <iconify-icon icon="solar:arrow-left-line-duotone" width="20"></iconify-icon>
        </div>
        <span class="font-extrabold text-sm uppercase tracking-widest hidden sm:block">Thoát chế độ</span>
    </a>

    <!-- Top Right Stats -->
    <div class="absolute top-8 right-8 z-20 flex items-center gap-4">
        <div class="bg-white/10 backdrop-blur-md border border-white/20 px-4 py-2 rounded-xl flex items-center gap-2">
            <iconify-icon icon="solar:fire-bold-duotone" width="20" class="text-[#F4831F]"></iconify-icon>
            <span class="font-bold">Hôm nay: <span class="text-[#F4831F]">120</span> phút</span>
        </div>
    </div>

    <!-- Center Content -->
    <div class="relative z-10 flex flex-col items-center justify-center w-full max-w-2xl px-6 text-center">
        
        <!-- Task Info -->
        <div class="mb-10 animate-fade-in-up">
            <p class="text-[#E8C9A0] font-extrabold text-xs uppercase tracking-[0.3em] mb-3 flex items-center justify-center gap-2">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                Đang tập trung
            </p>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight drop-shadow-lg">Tuyển tập CNN & ResNet</h1>
            <p class="text-white/60 font-medium mt-2">Môn: Deep Learning</p>
        </div>

        <!-- Timer Circle -->
        <div class="relative flex justify-center items-center w-64 h-64 md:w-80 md:h-80 mb-12">
            <!-- Outer Glow -->
            <div class="absolute inset-0 bg-[#F4831F]/20 rounded-full blur-3xl animate-pulse"></div>
            
            <!-- SVG Progress Circle -->
            <svg class="absolute inset-0 w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" class="stroke-[#3D2010]/50" stroke-width="3"></circle>
                <circle id="progress-ring" cx="50" cy="50" r="45" fill="none" class="stroke-[#F4831F] drop-shadow-lg" stroke-width="3" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="0"></circle>
            </svg>

            <!-- Time Text -->
            <div id="countdown-text" class="text-6xl md:text-8xl font-black tracking-tighter tabular-nums drop-shadow-xl z-10" style="font-variant-numeric: tabular-nums;">
                25:00
            </div>
        </div>

        <!-- Controls -->
        <div class="flex items-center gap-6">
            <button id="btn-reset" class="w-14 h-14 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-[#E8C9A0] hover:bg-white/20 hover:text-white transition-all">
                <iconify-icon icon="solar:restart-bold-duotone" width="24"></iconify-icon>
            </button>
            
            <button id="btn-play-pause" class="w-20 h-20 rounded-full bg-gradient-to-br from-[#F4831F] to-[#C8620F] flex items-center justify-center text-white shadow-[0_0_40px_rgba(244,131,31,0.4)] hover:scale-105 active:scale-95 transition-all outline-none">
                <iconify-icon id="icon-play" icon="solar:play-bold" width="36" class="ml-1"></iconify-icon>
                <iconify-icon id="icon-pause" icon="solar:pause-bold" width="36" class="hidden"></iconify-icon>
            </button>

            <button id="btn-skip" class="w-14 h-14 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-[#E8C9A0] hover:bg-white/20 hover:text-white transition-all hover:bg-red-500/80 hover:border-red-500">
                <iconify-icon icon="solar:stop-bold-duotone" width="24"></iconify-icon>
            </button>
        </div>
    </div>
    
    <!-- Rest Overlay (Hidden by default) -->
    <div id="rest-overlay" class="absolute inset-0 z-40 bg-gradient-to-br from-blue-900/95 to-slate-900/95 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-1000">
        <h2 class="text-5xl font-black text-white mb-4 drop-shadow-lg">Giỏi quá! Cùng nghỉ ngơi nào 💤</h2>
        <p class="text-blue-200 font-medium text-lg mb-8">Bạn vừa hoàn thành 1 phiên Pomodoro (25 phút).</p>
        <button id="btn-rest-start" class="bg-blue-500 text-white px-8 py-4 rounded-2xl font-black text-xl hover:bg-blue-400 hover:scale-105 transition-all shadow-lg shadow-blue-500/30">
            Bắt đầu nghỉ 5 phút
        </button>
    </div>

</div>

<!-- Only run script within this view. Since header/footer might be included by _Layout, this div overlays everything. -->
@section Scripts {
    <script>
        // DOM Elements
        const focusContainer = document.getElementById('focus-container');
        const bgImage = document.getElementById('bg-image');
        const progressRing = document.getElementById('progress-ring');
        const countdownText = document.getElementById('countdown-text');
        const btnPlayPause = document.getElementById('btn-play-pause');
        const iconPlay = document.getElementById('icon-play');
        const iconPause = document.getElementById('icon-pause');
        const btnReset = document.getElementById('btn-reset');
        const btnSkip = document.getElementById('btn-skip');
        const restOverlay = document.getElementById('rest-overlay');
        const btnRestStart = document.getElementById('btn-rest-start');

        // Layout Override (Hide sidebar and header of standard layout)
        document.body.classList.add('overflow-hidden');
        if (document.getElementById('sidebar')) document.getElementById('sidebar').style.display = 'none';
        if (document.querySelector('header')) document.querySelector('header').style.display = 'none';

        // Timer Vars
        const WORK_TIME = 25 * 60; // 25 mins
        const CIRCUMFERENCE = 2 * Math.PI * 45; // 283
        let timeLeft = WORK_TIME;
        let isRunning = false;
        let timerId = null;

        // Init SVG Circle
        progressRing.style.strokeDasharray = `${CIRCUMFERENCE} ${CIRCUMFERENCE}`;
        progressRing.style.strokeDashoffset = `0`;

        function updateDisplay() {
            const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
            const s = (timeLeft % 60).toString().padStart(2, '0');
            countdownText.textContent = `${m}:${s}`;
            
            const offset = CIRCUMFERENCE - (timeLeft / WORK_TIME) * CIRCUMFERENCE;
            progressRing.style.strokeDashoffset = offset;
        }

        function finishWork() {
            clearInterval(timerId);
            isRunning = false;
            // Switch Background to Resting Capy
            bgImage.src = '/images/tải xuống.jpg';
            bgImage.classList.remove('blur-sm');
            
            // Show Rest Overlay
            restOverlay.classList.remove('opacity-0', 'pointer-events-none');
            restOverlay.classList.add('opacity-100');
        }

        function toggleTimer() {
            if (isRunning) {
                clearInterval(timerId);
                iconPlay.classList.remove('hidden');
                iconPause.classList.add('hidden');
            } else {
                timerId = setInterval(() => {
                    if (timeLeft > 0) {
                        timeLeft--;
                        updateDisplay();
                    } else {
                        finishWork();
                    }
                }, 1000);
                iconPlay.classList.add('hidden');
                iconPause.classList.remove('hidden');
            }
            isRunning = !isRunning;
        }

        btnPlayPause.addEventListener('click', toggleTimer);

        btnReset.addEventListener('click', () => {
            clearInterval(timerId);
            isRunning = false;
            timeLeft = WORK_TIME;
            iconPlay.classList.remove('hidden');
            iconPause.classList.add('hidden');
            updateDisplay();
        });

        btnSkip.addEventListener('click', finishWork);

        btnRestStart.addEventListener('click', () => {
            // Fake 5 min rest -> close overlay, reset
            restOverlay.classList.add('opacity-0', 'pointer-events-none');
            restOverlay.classList.remove('opacity-100');
            bgImage.src = '/images/tải xuống (1).jpg';
            bgImage.classList.add('blur-sm');
            
            timeLeft = WORK_TIME;
            updateDisplay();
            iconPlay.classList.remove('hidden');
            iconPause.classList.add('hidden');
        });

        // Initialize display
        updateDisplay();
    </script>
}
