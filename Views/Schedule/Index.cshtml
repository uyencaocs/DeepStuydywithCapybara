@{
    ViewData["Title"] = "Lịch Trình";







    var days = new[] { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };







    var hours = Enumerable.Range(0, 24).Select(h => $"{h:D2}:00").ToList(); // 00:00 to 23:00
}

<div class="p-6 md:p-8 space-y-6 max-w-[1600px] mx-auto w-full">

    <!-- Hero Banner with Overlay -->
    <div class="gradient-card rounded-[2rem] overflow-hidden relative min-h-[160px] flex items-center shadow-lg">
        <!-- Overlay -->
        <div class="absolute inset-0 bg-[#000000]/60 z-0 pointer-events-none"></div>

        <!-- Text Content -->
        <div class="relative z-10 p-8 w-full md:w-1/2">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight drop-shadow-lg">Hành trình hôm nay của bạn 🎒
            </h2>
            <p class="text-white/80 font-medium drop-shadow-md">Sắp xếp thời gian thông minh, học tập nhàn tênh cùng
                Capy.</p>
        </div>

        <!-- Capy Backpack Image -->
        <div class="absolute right-0 top-0 bottom-0 w-1/3 md:w-1/4 pointer-events-none">
            <img src="~/images/tải xuống (2).jpg" alt="Capy Backpack"
                class="w-full h-full object-cover object-center opacity-90 drop-shadow-2xl">
        </div>
    </div>

    <!-- Toolbar -->
    <div
        class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white/80 backdrop-blur-md p-4 rounded-3xl border border-[#E8C9A0] shadow-sm">
        <div class="flex gap-2 items-center">
            <button
                class="bg-[#FDF1E3] text-black p-2 rounded-xl hover:bg-[#E8C9A0] transition-colors"><iconify-icon
                    icon="solar:alt-arrow-left-line-duotone" width="20"></iconify-icon></button>
            <div
                class="bg-white border border-[#E8C9A0] px-4 py-2 rounded-xl flex items-center justify-center font-black text-black shadow-sm tracking-wide">
                Tuần 20 - 26 Tháng 3, 2026
            </div>
            <button
                class="bg-[#FDF1E3] text-black p-2 rounded-xl hover:bg-[#E8C9A0] transition-colors"><iconify-icon
                    icon="solar:alt-arrow-right-line-duotone" width="20"></iconify-icon></button>
        </div>

        <button id="btn-optimize-ai"
            class="bg-gradient-to-r from-[#F4831F] to-[#C8620F] text-white px-6 py-3 rounded-2xl flex items-center gap-2 font-black text-sm shadow-lg shadow-orange-200 hover:-translate-y-0.5 active:scale-95 transition-all">
            <iconify-icon icon="solar:magic-stick-3-bold-duotone" width="20" class="animate-pulse"></iconify-icon>
            AI TỐI ƯU HÓA
        </button>
    </div>

    <!-- CSS Grid Calendar (6:00 - 23:00) -->
    <div class="bg-white rounded-[2.5rem] border border-[#E8C9A0] shadow-xl overflow-hidden flex flex-col h-[700px] w-full relative">

        <!-- Header Row (Days) -->
        <div class="grid grid-cols-8 border-b border-[#E8C9A0] bg-[#FDF1E3] sticky top-0 z-30">
            <div class="p-4 border-r border-[#E8C9A0]/50 text-center flex items-center justify-center">
                <iconify-icon icon="solar:clock-circle-bold-duotone" width="24" class="text-black"></iconify-icon>
            </div>
            @foreach (var day in days)
            {
                <div class="p-4 text-center border-r border-[#E8C9A0]/50 last:border-0 relative">
                    <p class="text-[11px] font-black text-black uppercase tracking-widest">@day</p>
                    @if (day == "Thứ 4")
                    {
                        <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#F4831F] rounded-t-lg"></div>
                        <p class="text-xl font-black text-black mt-1">25</p>
                    }
                    else
                    {
                        <p class="text-xl font-black text-black mt-1">@((23 + Array.IndexOf(days, day)).ToString())</p>
                    }
                </div>
            }
        </div>

        <!-- Scrollable Grid Body -->
        <div class="overflow-auto flex-1 custom-scrollbar relative">
            <div class="grid grid-cols-8 relative min-w-[700px] md:min-w-0">

                <!-- Time Column -->
                <div class="col-span-1 border-r border-[#E8C9A0]/50 bg-slate-50/50 sticky left-0 z-20">
                    @foreach (var hour in hours)







                    {
                        <div class="h-16 border-b border-dashed border-[#E8C9A0]/30 flex items-start justify-center pt-2">
                            <span class="text-[11px] font-bold text-black">@hour</span>
                        </div>
                    }
                </div>

                <!-- 7 Days Columns -->
                <div class="col-span-7 grid grid-cols-7 relative h-full">
                    <div class="absolute inset-0 grid grid-cols-7 pointer-events-none z-0">
                        @for (int i = 0; i < 7; i++)







                        {
                            <div class="border-r border-[#E8C9A0]/30 last:border-0 h-full"></div>
                        }
                    </div>
                    <div class="absolute inset-0 pointer-events-none flex flex-col z-0">
                        @foreach (var cur in hours)







                        {
                            <div class="h-16 w-full border-b border-dashed border-[#E8C9A0]/30 shrink-0"></div>
                        }
                    </div>

                    <!-- Hardcoded Event 1: Deep Learning -->
                    <!-- Tuesday (col 2): 10:00 to 12:00 (Starts at 10:00 -> 10*64=640px top, height 2*64=128px) -->
                    <div class="absolute w-[14.28%] px-1 z-10"
                        style="left: calc(14.28% * 1); top: 640px; height: 128px;">
                        <div
                            class="event-slot w-full h-full bg-[#FDF8F3] border-l-4 border-[#F4831F] rounded-xl p-3 shadow-md relative group hover:scale-[1.02] transition-transform cursor-pointer overflow-hidden"
                            data-title="Deep Learning" data-time="10:00 - 12:00" data-desc="Sắp thi cuối kỳ">
                            <span class="absolute top-2 right-2 flex h-2 w-2">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#E07A5F] opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#E07A5F]"></span>
                            </span>
                            <p class="text-[10px] font-black text-black">10:00 - 12:00</p>
                            <p class="text-xs font-black text-black leading-tight mt-1">Deep Learning</p>
                            <p class="text-[10px] text-black font-semibold mt-1">Sắp thi cuối kỳ</p>
                            <iconify-icon icon="solar:cpu-bold-duotone"
                                class="absolute bottom-1 right-2 text-black/20 group-hover:text-black/40 transition-colors"
                                width="36"></iconify-icon>
                        </div>
                    </div>

                    <!-- AI Suggested Slots -->
                    <!-- Thursday 09:00 - 11:00 (Starts at 09:00 -> 9*64=576px) -->
                    <div class="ai-suggestion absolute w-[14.28%] px-1 z-10 opacity-0 scale-95 transition-all duration-500"
                        style="left: calc(14.28% * 3); top: 576px; height: 128px;">
                        <div
                            class="event-slot w-full h-full bg-gradient-to-br from-[#FDF8F3] to-[#FDF1E3] border-2 border-dashed border-[#F4831F] rounded-xl p-2 relative flex flex-col items-center justify-center text-center cursor-pointer hover:border-solid hover:scale-[1.02]"
                            data-title="Làm bài tập CSDL" data-time="09:00 - 11:00" data-desc="Gợi ý AI tối ưu hóa thời gian">
                            <iconify-icon icon="solar:magic-stick-3-bold-duotone" class="text-black mb-1"
                                width="24"></iconify-icon>
                            <p class="text-[9px] font-black text-black uppercase">Gợi ý AI</p>
                            <p class="text-[11px] font-bold text-black leading-tight mt-0.5">Làm bài tập CSDL</p>
                        </div>
                    </div>

                    <!-- Saturday 14:00 - 16:00 (Starts at 14:00 -> 14*64=896px) -->
                    <div class="ai-suggestion absolute w-[14.28%] px-1 z-10 opacity-0 scale-95 transition-all duration-700"
                        style="left: calc(14.28% * 5); top: 896px; height: 128px;">
                        <div
                            class="event-slot w-full h-full bg-gradient-to-br from-[#FDF8F3] to-[#FDF1E3] border-2 border-dashed border-[#F4831F] rounded-xl p-2 relative flex flex-col items-center justify-center text-center cursor-pointer hover:border-solid hover:scale-[1.02]"
                            data-title="Ôn tập Deep Learning" data-time="14:00 - 16:00" data-desc="Gợi ý AI tối ưu hóa thời gian">
                            <iconify-icon icon="solar:magic-stick-3-bold-duotone" class="text-black mb-1"
                                width="24"></iconify-icon>
                            <p class="text-[9px] font-black text-black uppercase">Gợi ý AI</p>
                            <p class="text-[11px] font-bold text-black leading-tight mt-0.5">Ôn tập Deep Learning
                            </p>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Current Time Indicator (10:30 -> 10.5*64 = 672px) -->
            <div class="absolute left-0 right-0 border-t-2 border-[#E07A5F] z-30 pointer-events-none" style="top: 672px;">
                <div class="absolute -left-1.5 -top-2 w-4 h-4 bg-[#E07A5F] rounded-full border-2 border-white shadow-sm">
                </div>
            </div>
        </div>
        </div> <!-- End Calendar Main -->

        <!-- Analytics Section at Bottom -->
        <div class="mt-12 mb-8 px-6">
            <h3 class="text-xl font-black text-black mb-6 flex items-center gap-2">
                <iconify-icon icon="solar:chart-square-bold-duotone" class="text-black" width="24"></iconify-icon>
                Thống kê học tập theo môn
            </h3>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Deep Learning -->
                <div class="bg-white p-6 rounded-[2rem] border border-[#E8C9A0] shadow-sm">
                    <h4 class="text-sm font-black text-black text-center mb-4">Deep Learning</h4>
                    <div class="relative h-48 w-full">
                        <canvas id="chart-dl"></canvas>
                    </div>
                </div>
                <!-- TOEIC -->
                <div class="bg-white p-6 rounded-[2rem] border border-[#E8C9A0] shadow-sm">
                    <h4 class="text-sm font-black text-black text-center mb-4">Luyện thi TOEIC</h4>
                    <div class="relative h-48 w-full">
                        <canvas id="chart-toeic"></canvas>
                    </div>
                </div>
                <!-- CSDL -->
                <div class="bg-white p-6 rounded-[2rem] border border-[#E8C9A0] shadow-sm">
                    <h4 class="text-sm font-black text-black text-center mb-4">Cơ sở dữ liệu</h4>
                    <div class="relative h-48 w-full">
                        <canvas id="chart-csdl"></canvas>
                    </div>
                </div>
            </div>
        </div>

</div>

<!-- Event Detail Modal -->
<div id="event-modal" class="fixed inset-0 z-[100] bg-[#000000]/40 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-white rounded-[2rem] p-8 w-full max-w-sm border border-[#E8C9A0] shadow-2xl transform scale-95 transition-transform duration-300" id="event-modal-content">
        <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-black text-black" id="modal-title">Tên môn học</h3>
            <button id="btn-close-modal" class="text-black hover:text-black bg-[#FDF1E3] p-2 rounded-xl transition-colors">
                <iconify-icon icon="solar:close-circle-bold-duotone" width="20"></iconify-icon>
            </button>
        </div>
        <p class="text-sm font-bold text-black mb-1" id="modal-time">10:00 - 12:00</p>
        <p class="text-xs font-semibold text-black mb-6" id="modal-desc">Mô tả chi tiết...</p>
        <div class="flex gap-3">
            <button class="flex-1 bg-[#FDF1E3] text-black font-bold py-3 rounded-xl hover:bg-[#E8C9A0] transition-colors">Chỉnh sửa</button>
            <a href="/Focus" class="flex-[1.5] text-center bg-[#F4831F] text-white font-black py-3 rounded-xl hover:bg-[#C8620F] shadow-sm transition-colors active:scale-95">Vào Học</a>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // AI Tối Ưu Hóa Button
        document.getElementById('btn-optimize-ai').addEventListener('click', function () {
            var btn = this;

            btn.innerHTML = '<iconify-icon icon="solar:spuare-academic-bold-duotone" width="20" class="animate-spin"></iconify-icon> Đang phân tích...';
            btn.classList.add('opacity-80', 'cursor-not-allowed', 'scale-95');

            setTimeout(() => {
                const suggestions = document.querySelectorAll('.ai-suggestion');
                suggestions.forEach((el, index) => {
                    setTimeout(() => {
                        el.classList.remove('opacity-0', 'scale-95');
                        el.classList.add('opacity-100', 'scale-100');
                    }, index * 200);
                });

                btn.innerHTML = '<iconify-icon icon="solar:check-circle-bold-duotone" width="20"></iconify-icon> Đã tối ưu';
                btn.classList.remove('opacity-80', 'cursor-not-allowed', 'from-[#F4831F]', 'to-[#C8620F]', 'scale-95');
                btn.classList.add('from-green-500', 'to-emerald-600', 'scale-100');
            }, 1000);
        });

        // Common Options for Analytics Charts
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { family: 'Be Vietnam Pro', weight: 'bold', size: 10 } } }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: { color: '#000000', font: { family: 'Be Vietnam Pro', weight: 'bold', size: 10 } }
                },
                y: {
                    grid: { color: '#E8C9A0', borderDash: [4, 4], drawBorder: false },
                    ticks: { color: '#000000', font: { family: 'Be Vietnam Pro', size: 10 }, stepSize: 2 }
                }
            }
        };

        // Deep Learning Chart
        new Chart(document.getElementById('chart-dl').getContext('2d'), {
            type: 'bar',
            data: {
                labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                datasets: [
                    { label: 'Học tập (h)', data: [2.5, 3.8, 1.2, 4.0, 2.0, 5.5, 3.5], backgroundColor: '#F4831F', borderRadius: 4 },
                    { label: 'Focus (h)', data: [1.5, 2.0, 1.0, 3.0, 1.5, 4.0, 2.5], backgroundColor: '#8CA894', borderRadius: 4 }
                ]
            },
            options: commonOptions
        });

        // TOEIC Chart
        new Chart(document.getElementById('chart-toeic').getContext('2d'), {
            type: 'bar',
            data: {
                labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                datasets: [
                    { label: 'Học tập (h)', data: [1.0, 1.5, 2.0, 1.5, 2.5, 1.0, 2.0], backgroundColor: '#F4831F', borderRadius: 4 },
                    { label: 'Focus (h)', data: [0.5, 1.0, 1.5, 1.0, 2.0, 0.5, 1.5], backgroundColor: '#8CA894', borderRadius: 4 }
                ]
            },
            options: commonOptions
        });

        // CSDL Chart
        new Chart(document.getElementById('chart-csdl').getContext('2d'), {
            type: 'bar',
            data: {
                labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                datasets: [
                    { label: 'Học tập (h)', data: [3.0, 0, 4.0, 0, 3.5, 0, 2.0], backgroundColor: '#F4831F', borderRadius: 4 },
                    { label: 'Focus (h)', data: [2.0, 0, 3.0, 0, 2.5, 0, 1.5], backgroundColor: '#8CA894', borderRadius: 4 }
                ]
            },
            options: commonOptions
        });

        // Modal Logic
        const modal = document.getElementById('event-modal');
        const modalContent = document.getElementById('event-modal-content');
        const btnClose = document.getElementById('btn-close-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalTime = document.getElementById('modal-time');
        const modalDesc = document.getElementById('modal-desc');

        document.querySelectorAll('.event-slot').forEach(slot => {
            slot.addEventListener('click', function() {
                modalTitle.textContent = this.dataset.title;
                modalTime.textContent = this.dataset.time;
                modalDesc.textContent = this.dataset.desc;
                
                modal.classList.remove('opacity-0', 'pointer-events-none');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            });
        });

        btnClose.addEventListener('click', function() {
            modal.classList.add('opacity-0', 'pointer-events-none');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
        });

        // Close when clicking outside content
        modal.addEventListener('click', function(e) {
            if(e.target === modal) {
                btnClose.click();
            }
        });
    </script>
}
