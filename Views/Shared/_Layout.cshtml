<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapyStudy AI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DeeplearningwithCapybara.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap"
        rel="stylesheet">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root {
            --capy-brown: #6B4226;
            --capy-brown-mid: #8B5E3C;
            --capy-brown-light: #FDF1E3;
            --capy-orange: #F4831F;
            --capy-orange-dark: #C8620F;
            --capy-bg: #FEFBF6;
            --sidebar-w: 17rem;
            /* 272px */
        }

        * {
            font-family: 'Be Vietnam Pro', sans-serif;
        }

        body {
            background-color: var(--capy-bg);
            background-image: radial-gradient(#E7D9CC 1px, transparent 1px);
            background-size: 24px 24px;
            color: #3D2010;
        }

        /* ===== Collapsible Sidebar ===== */
        #sidebar {
            width: var(--sidebar-w);
            flex-shrink: 0;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), min-width 0.3s;
            overflow: hidden;
        }

        #sidebar.collapsed {
            width: 0 !important;
            min-width: 0 !important;
            border-right: none;
        }

        #sidebar .sidebar-label {
            transition: opacity 0.2s ease, transform 0.2s ease;
            transform-origin: left center;
        }

        #sidebar.collapsed .sidebar-label {
            opacity: 0;
            transform: scale(0);
            pointer-events: none;
        }

        #toggle-sidebar-btn {
            transition: background 0.2s;
        }

        /* ===== Sidebar Styling ===== */
        .sidebar-item-active {
            background: linear-gradient(90deg, rgba(107, 66, 38, 0.12) 0%, rgba(107, 66, 38, 0) 100%);
            border-left: 4px solid var(--capy-brown);
            color: var(--capy-brown) !important;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #D6C4AE;
            border-radius: 10px;
        }

        /* ===== Cards ===== */
        .glass-card {
            background: rgba(255, 252, 248, 0.9);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(240, 221, 200, 0.85);
            box-shadow: 0 8px 24px -8px rgba(107, 66, 38, 0.08);
        }

        .gradient-card {
            background: linear-gradient(135deg, var(--capy-brown) 0%, #3D2010 100%);
        }

        /* ===== Animations ===== */
        /* ===== Sidebar hover: white text on capy-brown ===== */
        #sidebar nav a:not(.sidebar-item-active):hover {
            background-color: var(--capy-brown) !important;
            color: #fff !important;
        }

        #sidebar nav a:not(.sidebar-item-active):hover iconify-icon {
            color: var(--capy-orange) !important;
        }

        /* whitespace nowrap prevents text wrapping during collapse */
        #sidebar {
            white-space: nowrap;
        }

        /* Profile Avatar fixed size */
        .profile-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 3px solid #E8C9A0;
            box-shadow: 0 4px 10px rgba(107, 66, 38, 0.15);
            object-fit: cover;
            display: block;
        }

        .capy-breathe {
            animation: breathe 4s ease-in-out infinite;
        }

        @@keyframes breathe {

            0%,
            100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.03);
            }
        }

        .animate-float {
            animation: float 6s ease-in-out infinite;
        }

        @@keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-14px);
            }
        }

        /* ===== Profile Dropdown ===== */
        .profile-dropdown {
            position: relative;
        }

        .profile-menu {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 12px);
            min-width: 220px;
            background: #fff;
            border: 1px solid #F3E4D0;
            border-radius: 1.25rem;
            box-shadow: 0 20px 40px -10px rgba(107, 66, 38, 0.2);
            z-index: 200;
            overflow: hidden;
        }

        .profile-dropdown:focus-within .profile-menu,
        .profile-dropdown:hover .profile-menu {
            display: block;
        }

        .profile-menu a,
        .profile-menu button {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            padding: 12px 18px;
            font-size: 0.875rem;
            font-weight: 600;
            color: #5c3d1e;
            background: none;
            border: none;
            text-decoration: none;
            text-align: left;
            cursor: pointer;
            transition: background 0.15s;
        }

        .profile-menu a:hover,
        .profile-menu button:hover {
            background: var(--capy-brown-light);
        }

        .profile-menu .menu-divider {
            height: 1px;
            background: #F3E4D0;
            margin: 4px 0;
        }

        .profile-menu .logout-btn {
            color: #c0392b;
        }

        .profile-menu .logout-btn:hover {
            background: #fff5f5;
        }
    </style>
</head>

<body class="min-h-screen flex">

    <!-- ===== SIDEBAR ===== -->
    <aside id="sidebar"
        class="bg-white/90 backdrop-blur-xl border-r border-[#F0DDC8] hidden lg:flex flex-col h-screen sticky top-0 z-30">
        <!-- Logo -->
        <div class="px-5 py-4 border-b border-[#F0DDC8] flex items-center gap-3 min-w-0">
            <div
                class="w-11 h-11 rounded-2xl overflow-hidden border-2 border-[#E8C9A0] shadow-md shrink-0 capy-breathe">
                <img src="~/images/capybaraa photocopy.jpg" alt="CapyStudy Logo" class="w-full h-full object-cover">
            </div>
            <div class="sidebar-label min-w-0">
                <p class="text-lg font-black text-[#3D2010] tracking-tight leading-none whitespace-nowrap">CapyStudy</p>
                <p class="text-[10px] font-bold text-[#A67C52] uppercase tracking-widest mt-0.5 whitespace-nowrap">AI
                    Study Planner</p>
            </div>
        </div>

        <nav class="flex-1 px-3 space-y-1 mt-5 overflow-y-auto custom-scrollbar">
            <a asp-controller="Home" asp-action="Index"
                class="flex items-center gap-3 px-4 py-3.5 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "sidebar-item-active font-bold text-[#6B4226]" : "text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3]") rounded-r-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:widget-add-bold-duotone" width="24"
                    class="shrink-0 group-hover:scale-110 transition-transform"></iconify-icon>
                <span class="sidebar-label">Dashboard</span>
            </a>
            <a asp-controller="Study" asp-action="Index"
                class="flex items-center gap-3 px-4 py-3.5 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Study" ? "sidebar-item-active font-bold text-[#6B4226]" : "text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3]") rounded-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:book-bookmark-bold-duotone" width="24"
                    class="shrink-0 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
                <span class="sidebar-label">Kế hoạch học tập</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-4 py-3.5 text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3] rounded-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:calendar-minimalistic-line-duotone" width="24"
                    class="shrink-0 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
                <span class="sidebar-label">Lịch Trình</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-4 py-3.5 text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3] rounded-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:chart-square-line-duotone" width="24"
                    class="shrink-0 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
                <span class="sidebar-label">Thống Kê</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-4 py-3.5 text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3] rounded-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:clock-circle-line-duotone" width="24"
                    class="shrink-0 group-hover:rotate-12 transition-transform"></iconify-icon>
                <span class="sidebar-label">Tập Trung</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-4 py-3.5 text-[#7A5C40] font-semibold hover:text-[#6B4226] hover:bg-[#FDF1E3] rounded-2xl transition-all group whitespace-nowrap">
                <iconify-icon icon="solar:settings-line-duotone" width="24"
                    class="shrink-0 group-hover:rotate-12 transition-transform"></iconify-icon>
                <span class="sidebar-label">Cài Đặt</span>
            </a>
        </nav>

        <!-- Upgrade Banner -->
        <div class="p-4 sidebar-label">
            <div
                class="bg-gradient-to-br from-[#FDF1E3] to-[#FAE3C6] border border-[#E8C38A] p-5 rounded-3xl relative overflow-hidden group">
                <div class="relative z-10">
                    <p class="text-[10px] font-extrabold text-[#A67C52] uppercase tracking-widest mb-1">Nâng cấp</p>
                    <p class="text-sm font-black text-[#3D2010] mb-3">CapyStudy Pro ✨</p>
                    <button
                        class="w-full bg-[#6B4226] text-white text-xs font-bold px-4 py-2.5 rounded-xl hover:bg-[#3D2010] transition-colors shadow-md">
                        Mở khóa ngay
                    </button>
                </div>
                <iconify-icon icon="solar:crown-minimalistic-bold-duotone"
                    class="absolute -right-3 -bottom-3 text-[#E8C38A]/60 group-hover:scale-110 transition-transform duration-500"
                    width="80"></iconify-icon>
            </div>
        </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="flex-1 flex flex-col min-h-screen overflow-x-hidden transition-all duration-300">
        <!-- Top Header -->
        <header
            class="h-20 bg-white/80 backdrop-blur-xl border-b border-[#F0DDC8] flex items-center justify-between px-6 sticky top-0 z-20">
            <div class="flex items-center gap-4">
                <!-- Sidebar Toggle Button -->
                <button id="toggle-sidebar-btn"
                    class="p-2.5 text-[#7A5C40] hover:text-[#3D2010] hover:bg-[#FDF1E3] rounded-xl transition-all border border-transparent hover:border-[#E8C9A0]"
                    title="Thu gọn / Mở rộng Sidebar">
                    <iconify-icon icon="solar:sidebar-minimalistic-line-duotone" width="24"></iconify-icon>
                </button>
                <div>
                    <h2 class="text-lg font-black text-[#3D2010] tracking-tight">Chào buổi sáng@(User.Identity != null
                        && User.Identity.IsAuthenticated ? $", {User.Identity.Name ?? ""}" : "")! 👋</h2>
                    <p class="text-xs text-[#A67C52] font-medium hidden sm:block mt-0.5">Sẵn sàng để hoàn thành mục tiêu
                        hôm nay chưa?</p>
                </div>
            </div>
            <div class="flex items-center gap-5">
                <!-- Search -->
                <div class="relative hidden md:block group">
                    <input type="text" placeholder="Tìm kiếm..."
                        class="bg-[#FDF1E3]/80 border border-[#E8C9A0] rounded-full pl-11 pr-5 py-2.5 text-sm w-56 focus:bg-white focus:ring-2 focus:ring-[#F4831F]/30 focus:border-[#F4831F] transition-all outline-none font-semibold placeholder:text-[#C4A882]">
                    <iconify-icon icon="solar:magnifer-linear" width="18"
                        class="absolute left-4 top-1/2 -translate-y-1/2 text-[#C4A882] group-focus-within:text-[#F4831F] transition-colors"></iconify-icon>
                </div>
                <!-- Notifications -->
                <button
                    class="relative p-2.5 text-[#A67C52] hover:text-[#6B4226] hover:bg-[#FDF1E3] transition-all bg-white rounded-full border border-[#E8C9A0] shadow-sm hover:shadow-md">
                    <iconify-icon icon="solar:bell-line-duotone" width="22"
                        style="color: var(--capy-orange);"></iconify-icon>
                    <span
                        class="absolute top-0 right-0 w-3 h-3 bg-red-500 rounded-full border-2 border-white animate-pulse"></span>
                </button>
                <!-- Profile Dropdown -->
                <div class="profile-dropdown pl-5 border-l border-[#E8C9A0]">
                    <div class="flex items-center gap-3 cursor-pointer select-none" tabindex="0">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-extrabold text-[#3D2010]">@(User.Identity != null &&
                                User.Identity.IsAuthenticated ? User.Identity.Name ?? "Khách" : "Khách")</p>
                            <p class="text-[10px] text-[#A67C52] font-bold uppercase tracking-wider mt-0.5">Thành viên
                            </p>
                        </div>
                        <div class="relative">
                            <img src="~/images/tải xuống.jpg" alt="Avatar" class="profile-avatar">
                            <div
                                class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 border-2 border-white rounded-full">
                            </div>
                        </div>
                        <iconify-icon icon="solar:alt-arrow-down-linear" width="14"
                            class="text-[#A67C52] shrink-0"></iconify-icon>
                    </div>
                    <div class="profile-menu">
                        <div class="px-4 py-3 border-b border-[#F3E4D0]">
                            <p class="text-xs font-black text-[#3D2010]">@(User.Identity != null &&
                                User.Identity.IsAuthenticated ? User.Identity.Name ?? "Người dùng" : "Khách viếng thăm")
                            </p>
                            <p class="text-[10px] text-[#A67C52] font-semibold mt-0.5">@(User.Identity != null &&
                                User.Identity.IsAuthenticated ? "Đã đăng nhập" : "Chưa đăng nhập")</p>
                        </div>
                        <a href="#"><iconify-icon icon="solar:user-circle-line-duotone" width="18"></iconify-icon>Hồ sơ
                            của tôi</a>
                        <a href="#"><iconify-icon icon="solar:settings-line-duotone" width="18"></iconify-icon>Cài
                            đặt</a>
                        <a href="#"><iconify-icon icon="solar:chart-square-line-duotone" width="18"></iconify-icon>Thống
                            kê nâng cao</a>
                        <div class="menu-divider"></div>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)



                        {
                            <form asp-area="Identity" asp-page="/Account/Logout"
                                asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="logout-btn"><iconify-icon icon="solar:logout-2-bold-duotone"
                                        width="18"></iconify-icon>Đăng xuất</button>
                            </form>
                        }



                        else



                        {
                            <a asp-area="Identity" asp-page="/Account/Login"><iconify-icon icon="solar:login-2-bold-duotone"
                                    width="18"></iconify-icon>Đăng nhập / Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </header>

        <!-- Dynamic Body -->
        <div class="w-full flex-1">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Collapsible Sidebar JS -->
    <script>
        (function () {
            const sidebar = document.getElementById('sidebar');
            const btn = document.getElementById('toggle-sidebar-btn');
            const STORAGE_KEY = 'capystudy_sidebar_collapsed';

            // Restore state from localStorage
            if (localStorage.getItem(STORAGE_KEY) === 'true') {
                sidebar.classList.add('collapsed');
            }

            btn.addEventListener('click', function () {
                const isCollapsed = sidebar.classList.toggle('collapsed');
                localStorage.setItem(STORAGE_KEY, isCollapsed);
                // Update button icon
                const icon = btn.querySelector('iconify-icon');
                icon.setAttribute('icon', isCollapsed
                    ? 'solar:sidebar-minimalistic-bold-duotone'
                    : 'solar:sidebar-minimalistic-line-duotone');
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
