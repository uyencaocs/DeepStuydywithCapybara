@using System.Security.Claims



@{
    var displayName = ViewBag.DisplayName ?? "User";
    var email = ViewBag.Email ?? "";
    var joinDate = ViewBag.JoinDate ?? "";
    var major = ViewBag.Major ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CapyStudy AI</title>

    <!-- Outfit font + Iconify (kept per requirement) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <style>
        /* Preserve original design tokens required by the spec */
        .bg-gradient-mesh {
            background-color: #f3e8e2;
            background-image:
                radial-gradient(at 10% 20%, rgba(139, 92, 246, 0.2) 0px, transparent 50%),
                radial-gradient(at 90% 10%, rgba(245, 158, 11, 0.2) 0px, transparent 50%),
                radial-gradient(at 30% 80%, rgba(253, 224, 71, 0.2) 0px, transparent 50%),
                radial-gradient(at 80% 90%, rgba(139, 92, 246, 0.3) 0px, transparent 50%);
            background-attachment: fixed;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 20px 40px -12px rgba(0,0,0,0.08);
        }

        body, input, button, textarea {
            font-family: 'Outfit', system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        }
    </style>
</head>

<body class="bg-gradient-mesh min-h-screen flex items-center justify-center py-10">
    <main class="glass-panel max-w-4xl w-full rounded-2xl overflow-hidden">
        <!-- Cover / Header -->
        <header class="relative">
            <div class="h-40 md:h-44 bg-gradient-to-r from-purple-300 via-orange-200 to-yellow-100"></div>

            <!-- Avatar (overlapping) -->
            <div class="absolute left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                <div class="w-32 h-32 md:w-36 md:h-36 rounded-full border-4 border-white overflow-hidden shadow-xl">
                    <img src="~/images/auth-capy.png" alt="Avatar" class="w-full h-full object-cover">
                </div>
            </div>
        </header>

        <!-- Body content -->
        <section class="pt-20 pb-8 px-6 md:px-8">
            <!-- Identity row -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div class="text-center md:text-left">
                    <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight">@displayName</h1>
                    <div class="mt-2 flex items-center justify-center md:justify-start gap-2">
                        <span class="inline-block text-xs font-semibold bg-[#FDF1E3] px-3 py-1 rounded-full text-slate-800 border border-[#E8C9A0]">
                            Page
                        </span>
                        <button class="ml-2 inline-flex items-center gap-2 text-sm font-bold bg-[#6B4226] text-white px-3 py-1.5 rounded-lg shadow-sm hover:bg-black transition">
                            <iconify-icon icon="solar:edit-bold" width="16"></iconify-icon>
                            Sửa hồ sơ
                        </button>
                    </div>
                </div>

                <!-- Action quick area (desktop) -->
                <div class="hidden md:flex items-center gap-3">
                    <a href="#" class="text-sm font-bold text-slate-600 hover:text-slate-800">Chia sẻ hồ sơ</a>
                    <a href="#" class="text-sm font-bold text-slate-600 hover:text-slate-800">Lịch sử hoạt động</a>
                </div>
            </div>

            <!-- Main grid -->
            <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Left column: personal info (col-span-1) -->
                <div class="col-span-1 bg-white/60 rounded-xl p-5 border border-[#E8C9A0]">
                    <h3 class="text-sm font-black mb-4">Thông tin cá nhân</h3>
                    <dl class="space-y-4 text-sm text-slate-800">
                        <div class="flex flex-col">
                            <dt class="text-xs font-bold uppercase text-slate-500">Email</dt>
                            <dd class="mt-1 font-semibold">@email</dd>
                        </div>
                        <div class="flex flex-col">
                            <dt class="text-xs font-bold uppercase text-slate-500">Ngày tham gia</dt>
                            <dd class="mt-1 font-semibold">@joinDate</dd>
                        </div>
                        <div class="flex flex-col">
                            <dt class="text-xs font-bold uppercase text-slate-500">Chuyên ngành</dt>
                            <dd class="mt-1 font-semibold">@major</dd>
                        </div>
                    </dl>
                </div>

                <!-- Right area occupies two columns in desktop -->
                <div class="md:col-span-2 space-y-6">
                    <!-- Stats cards (three horizontal) -->
                    <div class="flex flex-col sm:flex-row gap-4">
                        <div class="flex-1 bg-white/70 rounded-xl p-4 border border-[#E8C9A0] shadow-sm flex flex-col items-start">
                            <p class="text-xs font-black uppercase text-slate-500">Ngày học liên tục</p>
                            <p class="text-2xl font-extrabold text-slate-900 mt-2">14 <span class="text-sm font-semibold text-slate-600">Ngày</span></p>
                        </div>
                        <div class="flex-1 bg-white/70 rounded-xl p-4 border border-[#E8C9A0] shadow-sm flex flex-col items-start">
                            <p class="text-xs font-black uppercase text-slate-500">Giờ tập trung</p>
                            <p class="text-2xl font-extrabold text-slate-900 mt-2">92 <span class="text-sm font-semibold text-slate-600">Giờ</span></p>
                        </div>
                        <div class="flex-1 bg-white/70 rounded-xl p-4 border border-[#E8C9A0] shadow-sm flex flex-col items-start">
                            <p class="text-xs font-black uppercase text-slate-500">Task hoàn thành</p>
                            <p class="text-2xl font-extrabold text-slate-900 mt-2">128 <span class="text-sm font-semibold text-slate-600">Task</span></p>
                        </div>
                    </div>

                    <!-- Account management -->
                    <div class="bg-white/60 rounded-xl p-5 border border-[#E8C9A0]">
                        <h3 class="text-sm font-black mb-4">Quản lý tài khoản</h3>
                        <div class="space-y-4 text-sm text-slate-800">
                            <!-- Change password -->
                            <div>
                                <a href="#" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#FDF1E3] transition">
                                    <iconify-icon icon="solar:lock-bold" class="text-2xl text-slate-600"></iconify-icon>
                                    <div class="flex-1">
                                        <h4 class="font-semibold">Đổi mật khẩu</h4>
                                        <p class="text-xs text-slate-500">Cập nhật mật khẩu cho tài khoản của bạn</p>
                                    </div>
                                    <iconify-icon icon="solar:chevron-right-bold" class="text-xl text-slate-400"></iconify-icon>
                                </a>
                            </div>

                            <!-- Manage subscriptions (conditional) -->
                            @if (User.IsSubscribe())
                            {
                                <div>
                                    <a href="#" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#FDF1E3] transition">
                                        <iconify-icon icon="solar:star-bold" class="text-2xl text-slate-600"></iconify-icon>
                                        <div class="flex-1">
                                            <h4 class="font-semibold">Quản lý gói học</h4>
                                            <p class="text-xs text-slate-500">Xem và thay đổi gói học của bạn</p>
                                        </div>
                                        <iconify-icon icon="solar:chevron-right-bold" class="text-xl text-slate-400"></iconify-icon>
                                    </a>
                                </div>
                            }

                            <!-- Logout button -->
                            <div>
                                <a href="/Logout" class="flex items-center gap-3 p-3 rounded-lg bg-red-50 hover:bg-red-100 transition">
                                    <iconify-icon icon="solar:logout-bold" class="text-2xl text-red-600"></iconify-icon>
                                    <div class="flex-1">
                                        <h4 class="font-semibold text-red-600">Đăng xuất</h4>
                                        <p class="text-xs text-red-500">Đăng xuất khỏi tài khoản của bạn</p>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>