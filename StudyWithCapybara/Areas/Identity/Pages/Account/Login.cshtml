@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    :root {
        --capybara-brown: #A65E2E; /* Màu nâu sáng (nút bấm) */
        --capybara-deep-brown: #4A2E1B; /* Màu nâu đậm (chữ) */
        --capybara-bg: #FAF3E0; /* Màu nền be nhạt */
    }

    body {
        background-color: var(--capybara-bg);
        color: var(--capybara-deep-brown);
    }

    .capybara-card {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(74, 46, 27, 0.08); /* Bóng đổ tiệp màu nâu */
        padding: 45px 35px;
        max-width: 420px;
        width: 100%;
        margin: auto;
        border: 1px solid rgba(166, 94, 46, 0.1);
    }

    .capybara-btn {
        background-color: var(--capybara-brown);
        color: white;
        border-radius: 14px;
        padding: 14px;
        font-weight: 700;
        font-size: 1.1rem;
        border: none;
        transition: all 0.3s ease;
    }

        .capybara-btn:hover {
            background-color: var(--capybara-deep-brown);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(74, 46, 27, 0.2);
        }

    .form-control-custom {
        background-color: #FCFBF9;
        border: 1.5px solid #EAE3D9;
        border-radius: 12px;
        padding: 12px 15px;
        color: var(--capybara-deep-brown);
    }

        .form-control-custom:focus {
            box-shadow: 0 0 0 4px rgba(166, 94, 46, 0.15);
            border-color: var(--capybara-brown);
        }

    .form-check-input:checked {
        background-color: var(--capybara-brown);
        border-color: var(--capybara-brown);
    }

    .toggle-password {
        position: absolute;
        top: 50%;
        right: 15px;
        transform: translateY(-50%);
        cursor: pointer;
        color: #BDB5AD;
        font-size: 1.2rem;
        z-index: 10;
        transition: color 0.3s;
    }

        .toggle-password:hover {
            color: var(--capybara-brown);
        }
</style>

<div class="d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="capybara-card text-center">
        <div class="mb-3">
            <img src="~/images/capybara.png" alt="Logo của tôi" class="img-fluid" style="max-height: 80px;">
        </div>

        <h3 class="fw-bold mb-2" style="color: var(--capybara-deep-brown);">Chào mừng trở lại!</h3>
        <p class="mb-4 small" style="color: #8A7B70;">Tiếp tục hành trình học tập thật chill nhé!</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-start small"></div>

            <div class="form-floating mb-3 text-start">
                <input asp-for="Input.Email" class="form-control form-control-custom" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" style="color: #8A7B70;"><i class="bi bi-envelope me-2"></i>Email của bạn</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3 text-start position-relative">
                <input asp-for="Input.Password" class="form-control form-control-custom" autocomplete="current-password" aria-required="true" placeholder="password" type="password" />
                <label asp-for="Input.Password" style="color: #8A7B70;"><i class="bi bi-lock me-2"></i>Mật khẩu</label>
                <i class="bi bi-eye-slash toggle-password" id="toggleEyeLogin"></i>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check text-start">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label small fw-medium" asp-for="Input.RememberMe" style="color: #8A7B70;">
                        Ghi nhớ đăng nhập
                    </label>
                </div>
                <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none fw-bold" style="color: var(--capybara-brown);">Quên mật khẩu?</a>
            </div>

            <button id="login-submit" type="submit" class="w-100 capybara-btn mb-4">Đăng nhập</button>

            <div>
                <p class="small mb-0" style="color: #8A7B70;">
                    Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color: var(--capybara-brown);">Đăng ký ngay</a>
                </p>
            </div>
        </form>
    </div>
</div>

<style>
    .role-toggle-container {
        display: flex;
        justify-content: center;
        margin-bottom: 25px;
    }

    .role-toggle {
        background-color: #f1f1f1;
        border-radius: 30px;
        display: inline-flex;
        padding: 5px;
        width: 100%;
        max-width: 350px;
    }

    .role-btn {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px 20px;
        border-radius: 25px;
        font-weight: bold;
        color: #666;
        transition: all 0.3s ease;
    }

        .role-btn.active {
            background-color: #ffffff;
            color: #A65E2E; /* Màu nâu Capybara */
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
</style>

<div class="role-toggle-container">
    <div class="role-toggle">
        <button type="button" class="role-btn active" id="btnStudent" onclick="selectRole('Student')">Học sinh</button>
        <button type="button" class="role-btn" id="btnAdmin" onclick="selectRole('Admin')">Quản trị viên</button>
    </div>
</div>

<input type="hidden" id="SelectedRole" name="Input.SelectedRole" value="Student" />

<script>
    function selectRole(role) {
        // Cập nhật giá trị cho input ẩn
        document.getElementById('SelectedRole').value = role;

        // Đổi màu nút
        if(role === 'Admin') {
            document.getElementById('btnAdmin').classList.add('active');
            document.getElementById('btnStudent').classList.remove('active');
        } else {
            document.getElementById('btnStudent').classList.add('active');
            document.getElementById('btnAdmin').classList.remove('active');
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/password-toggle.js"></script>
}